APP_NAME=Traffic Intelligence API
APP_VERSION=0.1.0
ENVIRONMENT=development
API_V1_PREFIX=/api/v1

DATABASE_URL=postgresql+asyncpg://traffic_user:traffic_password@localhost:5432/traffic_intelligence
DATABASE_ECHO=false

VIDEO_STORAGE_PATH=storage/videos
MAX_VIDEO_UPLOAD_MB=500
UPLOAD_CHUNK_SIZE_BYTES=1048576

WORKER_POLL_INTERVAL_SECONDS=2
WORKER_LEASE_SECONDS=120
WORKER_PROGRESS_INTERVAL_FRAMES=10
WORKER_MAX_ATTEMPTS=3
WORKER_RECOVERY_BATCH_SIZE=20

DETECTOR_MODEL_PATH=yolo26n.pt
DETECTOR_DEVICE=auto
DETECTOR_CONFIDENCE_THRESHOLD=0.35
DETECTOR_IOU_THRESHOLD=0.50
DETECTOR_IMAGE_SIZE=640

EVIDENCE_STORAGE_PATH=storage/evidence

DETECTOR_FRAME_STRIDE=5

EVIDENCE_MIN_CONFIDENCE=0.65
EVIDENCE_COOLDOWN_FRAMES=30
MAX_EVIDENCE_FRAMES=20

ANNOTATED_PREVIEW_ENABLED=true

TRACKER_HIGH_CONFIDENCE_THRESHOLD=0.60
TRACKER_LOW_CONFIDENCE_THRESHOLD=0.35

TRACKER_PRIMARY_IOU_THRESHOLD=0.30
TRACKER_SECONDARY_IOU_THRESHOLD=0.15

TRACKER_MIN_CONFIRMED_HITS=2
TRACKER_MAX_MISSED_FRAMES=12

TRACKER_PROCESS_NOISE=1.0
TRACKER_MEASUREMENT_NOISE=10.0

RIDER_ASSOCIATION_MINIMUM_SCORE=0.55
RIDER_ASSOCIATION_MAX_RIDERS_PER_MOTORCYCLE=3

RIDER_ASSOCIATION_MAX_ANCHOR_DISTANCE_RATIO=2.0
RIDER_ASSOCIATION_MINIMUM_HORIZONTAL_OVERLAP=0.05

RIDER_ASSOCIATION_MINIMUM_MOTION_SPEED=5.0

RIDER_TEMPORAL_CONFIRMATION_FRAMES=3
RIDER_TEMPORAL_MAX_MISSED_FRAMES=2
RIDER_TEMPORAL_SCORE_ALPHA=0.40